{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kestra notes",
  "version": "0.1.2",
  "identifier": "com.dee.kestra-notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kestra Notes",
        "width": 1024,
        "height": 720,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 24 }
      }
    ],
   
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCMjNENzI5RTdCQjg2REEKUldUYWhydm5LZGNqeTJsdXdOaVVBTmQvWURhajM5SjJreFBFejZmNXdBdUdmQWtXOUkrWGJWcWIK",
      "endpoints": [
        "https://github.com/deecaulcrick/kestra-notes/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
